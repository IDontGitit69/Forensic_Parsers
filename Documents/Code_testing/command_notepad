sudo find /mnt/vmfs -exec stat --format="%n|%i|%a|%u|%g|%s|%X|%Y|%Z|%W" {} \; > /path/to/full_metadata.txt
sudo find /mnt/vmfs -printf "%T+ %A+ %C+ %n %U %G %s %p\n" > /path/to/timestamps_backup.txt

jq -rs '
  [ .[] |
    select(.module == "Filescan") |
    select(.reasons != null) |
    .file.path as $filepath |
    .reasons[]? |
    select(.name != null) |
    {reason: .name, file: $filepath}
  ] |
  group_by(.reason) |
  .[] |
  "\nRule: " + .[0].reason + "\n" +
  (to_entries | map("  " + (.key + 1 | tostring) + ". " + .value.file) | join("\n"))
' thor_scan.json
