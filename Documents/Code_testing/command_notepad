' ─────────────────────────────────────────────────
' Uniform Crop + Resize — All Images in Document
' Adjust the four values below, then run the macro.
' ─────────────────────────────────────────────────

Sub CropAndResizeAllImages()

    ' ── SETTINGS — change these values ──────────────
    Const FINAL_WIDTH_INCHES  As Double = 6.5  ' display width
    Const CROP_BOTTOM_INCHES  As Double = 0.0  ' trim from bottom
    Const CROP_RIGHT_INCHES   As Double = 0.0  ' trim from right
    Const LOCK_ASPECT_RATIO   As Boolean = True ' keep proportions
    ' ─────────────────────────────────────────────────

    Dim oShape  As InlineShape
    Dim PPC     As Double
    PPC = 72  ' points per inch

    For Each oShape In ActiveDocument.InlineShapes

        If oShape.Type = wdInlineShapeLinkedPicture Or _
           oShape.Type = wdInlineShapePicture Then

            With oShape.PictureFormat.Crop
                .CropBottom = CROP_BOTTOM_INCHES * PPC
                .CropRight  = CROP_RIGHT_INCHES  * PPC
            End With

            If LOCK_ASPECT_RATIO Then
                oShape.LockAspectRatio = msoTrue
            End If

            oShape.Width = FINAL_WIDTH_INCHES * PPC

        End If

    Next oShape

    MsgBox "Done! " & ActiveDocument.InlineShapes.Count & _
           " image(s) updated.", vbInformation

End Sub
