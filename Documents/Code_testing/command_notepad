for i in $(seq 0 31); do
    if [ -e "/sys/block/nbd${i}/pid" ] || [ "$(cat /sys/block/nbd${i}/size 2>/dev/null)" != "0" ]; then
        echo "nbd${i} is active"
    fi
done


for i in $(seq 0 31); do
    if [ -e "/sys/block/nbd${i}/pid" ] || [ "$(cat /sys/block/nbd${i}/size 2>/dev/null)" != "0" ]; then
        echo "Disconnecting /dev/nbd${i}..."
        kpartx -d /dev/nbd${i} 2>/dev/null
        qemu-nbd --disconnect /dev/nbd${i} 2>/dev/null
    fi
done


for i in $(seq 0 31); do
    kpartx -d /dev/nbd${i} 2>/dev/null
done


for i in $(seq 0 31); do
    qemu-nbd --disconnect /dev/nbd${i} 2>/dev/null
done


sudo dmsetup ls | grep -v "^control" | awk '{print $1}' | while read name; do
    sudo dmsetup remove "$name" 2>/dev/null && echo "Removed: $name"
done

